{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Vulcan",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_vulcan.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--type",
                "multi-large",
                "--measurement_noise",
                "0.2"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "RH-MA-Vulcan",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_rh_ma_vulcan.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--type",
                "single-small",
                "--measurement_noise",
                "0.2",
                "--logging_level",
                "debug"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "MAPF-Suite",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_mapf_suite.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--map_type",
                "maze-32",
                "--logging_level",
                "debug",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "MAPF Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/analyze_mapf_suite_results.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--results_pkl",
                // "results_dense.pkl",
                "augmented_results_maze-32.pkl"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Real-World-Testing",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_real_world_setup.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--logging_level",
                "debug",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Real-World Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/analyze_real_world_setup_results.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--results_pkl",
                "augmented_results_real-world-dataset.xyz.pkl",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Current File with Profiler",
            "type": "debugpy",
            "request": "launch",
            "module": "cProfile",
            "args": [
                "-o",
                "/tmp/tmp.prof",
                "${file}"
            ],
        },
    ]
}
