{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Vulcan",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_vulcan.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--type",
                "multi-large",
                "--measurement_noise",
                "0.2"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "RH-MA-Vulcan",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_rh_ma_vulcan.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--type",
                "multi-large",
                "--measurement_noise",
                "0.2"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Current File with Profiler",
            "type": "debugpy",
            "request": "launch",
            "module": "cProfile",
            "args": [
                "-o",
                "/tmp/tmp.prof",
                "${file}"
            ],
        }
    ]
}
